NODE_ENV=development
PORT=5000

JWT_SECRET=ADD_YOUR_SECRET
MONGO_URI=ADD_YOUR_MONGO_URI

PAGINATION_LIMIT=4

# URLs — for local dev set BACKEND_URL to your ngrok/Expose public tunnel URL
# so PayFast can reach your notify endpoint. In production use your real domain.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# PayFast Onsite Integration
PAYFAST_MERCHANT_ID=ADD_YOUR_MERCHANT_ID
PAYFAST_MERCHANT_KEY=ADD_YOUR_MERCHANT_KEY
PAYFAST_PASSPHRASE=ADD_YOUR_PASSPHRASE

# SendGrid Email Configuration
SENDGRID_API_KEY=ADD_YOUR_SENDGRID_KEY
EMAIL_FROM=your@email.com
EMAIL_FROM_NAME=YourStoreName
